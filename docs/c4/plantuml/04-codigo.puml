@startuml codigo
skinparam backgroundColor #000000
skinparam class {
  BackgroundColor #000000
  BorderColor #FFFFFF
  FontColor #FFFFFF
  ArrowColor #FFFFFF
}
skinparam ArrowColor #FFFFFF
skinparam defaultFontColor #FFFFFF

class App {
  +configureMiddlewares()
  +mountRoutes()
  +listen(PORT)
}

class TicketsRoutes
class UsersRoutes

class TicketsController {
  +index(req,res)
  +show(req,res)
  +summary(req,res)
  +store(req,res)
  +update(req,res)
  +addComment(req,res)
}

class UsersController {
  +index(req,res)
}

class TicketsService {
  +listTickets(filters)
  +getTicketById(id)
  +getTicketSummary(id)
  +createTicket(ticketData)
  +updateTicket(id, updateData)
  +addComment(ticketId, commentData)
}

class TicketsRepository {
  +findAll()
  +findById(id)
  +create(data)
  +update(id,data)
}

class CommentsRepository {
  +findByTicketId(ticketId)
  +create(data)
}

class UsersRepository {
  +findAll()
  +findById(id)
}

class ErrorMiddleware {
  +handle(err,req,res,next)
}

class IdUtil {
  +generateId()
}

App --> TicketsRoutes
App --> UsersRoutes
App --> ErrorMiddleware

TicketsRoutes --> TicketsController
UsersRoutes --> UsersController

TicketsController --> TicketsService
UsersController --> UsersRepository

TicketsService --> TicketsRepository
TicketsService --> CommentsRepository

TicketsRepository --> IdUtil
CommentsRepository --> IdUtil

@enduml
